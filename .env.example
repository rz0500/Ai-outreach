# Copy this file to .env and fill in your values.
# Never commit .env to version control.

ANTHROPIC_API_KEY=your_api_key_here
CALENDAR_LINK=https://calendly.com/your-handle/30min

# Module 7 - SMTP mailer
# Gmail example: SMTP_HOST=smtp.gmail.com, SMTP_PORT=465
# Use an App Password, not your Google account password.
# Generate one at: Google Account > Security > 2-Step Verification > App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your_app_password_here

# Module 8 - IMAP Inbox Monitor
# Optional: IMAP will default to SMTP credentials if not provided
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=you@gmail.com
IMAP_PASSWORD=your_app_password_here
IMAP_MAX_MESSAGES_PER_POLL=25

# Social Automation Credentials (Playwright)
LINKEDIN_USER=your_linkedin_email@domain.com
LINKEDIN_PASS=your_linkedin_password

# Twilio Credentials (SMS)
TWILIO_ACCOUNT_SID=AC_your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# SendGrid API (Replaces SMTP for robust domain rotation)
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
SENDER_EMAILS=hello@yourdomain1.com,hello@yourdomain2.com

# Module 10 - Google Maps Scraper
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Scheduler
INBOX_POLL_INTERVAL=300       # seconds between inbox polls (min 60)
SEQUENCE_RUN_HOUR=9           # UTC hour to run daily sequence dispatch (0-23)

# SendGrid routing (set to true to use SendGrid instead of SMTP)
USE_SENDGRID=false
LINKEDIN_DRY_RUN=true

# Sender display name (used in email sign-offs)
SENDER_NAME=Alex

# Settings page Basic Auth (change these before going live)
SETTINGS_USER=admin
SETTINGS_PASSWORD=admin

# Flask session secret key (change to a random string in production)
SECRET_KEY=change-this-to-a-random-secret

# Autonomous self-prospecting (house account — leave blank to disable)
SELF_PROSPECT_NICHE=marketing agency    # Google Maps search query
SELF_PROSPECT_LOCATION=London           # Search location
SELF_PROSPECT_DAILY_LIMIT=5             # Max new prospects per day
SELF_PROSPECT_RUN_HOUR=7                # UTC hour to run (0-23)
