# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Core AI ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Google Maps (lead discovery) ─────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ── SMTP (outbound email) ────────────────────────────────────────────────────
# Gmail: use an App Password (Google Account > Security > 2-Step > App passwords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your_app_password_here

# ── IMAP (inbox monitor) ─────────────────────────────────────────────────────
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=you@gmail.com
IMAP_PASSWORD=your_app_password_here
IMAP_MAX_MESSAGES_PER_POLL=25

# ── SendGrid (optional — overrides SMTP when USE_SENDGRID=true) ──────────────
USE_SENDGRID=false
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
# Optional: verify signed webhook events from SendGrid
# SENDGRID_WEBHOOK_PUBLIC_KEY=

# ── Flask ────────────────────────────────────────────────────────────────────
# REQUIRED — app will refuse to start if this is missing or still the placeholder.
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret

# Enable Werkzeug debug mode in development only (never true in production)
FLASK_DEBUG=false

# Port to bind (Heroku/Render set this automatically)
# PORT=5000

# Public base URL — used to build absolute links (e.g. unsubscribe) in background threads
# Set this to your deployed domain in production
APP_BASE_URL=https://yourdomain.com

# ── Operator notifications ────────────────────────────────────────────────────
# Receives new lead alerts (from /onboard) and daily pipeline reports
OPERATOR_EMAIL=you@yourdomain.com

# ── Settings + Ops Basic Auth ────────────────────────────────────────────────
# Protects /settings, /ops, and /api/ops/* action endpoints
SETTINGS_USER=admin
# REQUIRED — app will refuse to start if this is still "change-me" or empty.
SETTINGS_PASSWORD=change-me

# ── Database path ─────────────────────────────────────────────────────────────
# Default: prospects.db in the project root (fine for local dev).
# On Render/Railway/Fly you MUST mount a persistent disk and set this — otherwise
# the database is wiped on every redeploy. Example (Render persistent disk):
DB_PATH=/var/data/prospects.db

# ── Sender display name ───────────────────────────────────────────────────────
# Fallback name used in email sign-offs if no client sender_name is set
SENDER_NAME=Alex

# ── Booking link ─────────────────────────────────────────────────────────────
CALENDAR_LINK=https://calendly.com/your-handle/30min

# ── Autonomous self-prospecting (house account) ───────────────────────────────
# Leave blank to disable daily Google Maps discovery for the house account
SELF_PROSPECT_NICHE=marketing agency
SELF_PROSPECT_LOCATION=London
SELF_PROSPECT_DAILY_LIMIT=5
SELF_PROSPECT_RUN_HOUR=7

# ── Scheduler ────────────────────────────────────────────────────────────────
INBOX_POLL_INTERVAL=300       # seconds between inbox polls (min 60)
SEQUENCE_RUN_HOUR=9           # UTC hour to run daily sequence dispatch (0-23)
# Set to false to disable the background scheduler entirely
# SCHEDULER_ENABLED=true

# ── LinkedIn (dry-run by default — no real sends) ─────────────────────────────
LINKEDIN_DRY_RUN=true
LINKEDIN_USER=your_linkedin_email@domain.com
LINKEDIN_PASS=your_linkedin_password

# ── Twilio SMS ────────────────────────────────────────────────────────────────
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_PHONE_NUMBER=+1234567890

# ── Mailivery external email warmup (optional) ────────────────────────────────
# When enabled, new client mailboxes are auto-connected to Mailivery on onboard.
# Health scores are refreshed every 4 hours and displayed on the client dashboard.
# Set MAILIVERY_ENABLED=true and provide your API key from app.mailivery.io/api.
MAILIVERY_ENABLED=false
# MAILIVERY_API_KEY=your_mailivery_api_key_here
# Required for /webhook/mailivery; send this value as X-Mailivery-Webhook-Secret.
# MAILIVERY_WEBHOOK_SECRET=change-this-to-a-random-webhook-secret
# Owner email shown in Mailivery dashboard for all managed campaigns:
# MAILIVERY_OWNER_EMAIL=you@yourdomain.com
